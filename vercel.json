{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install --legacy-peer-deps --no-audit --no-fund",
  "framework": null,
  "rewrites": [
    {
      "source": "/((?!api|favicon.ico|assets/).*)",
      "destination": "/api/ssr"
    }
  ]
}
